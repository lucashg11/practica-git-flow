---
interface Props {
    titulo: string;
    subtitulo: string;
}

const {titulo, subtitulo} = Astro.props;
---

<section class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight">{titulo}</h1>
    <p class="mt-4 text-lg md:text-xl text-gray-500 max-w-2xl">{subtitulo}</p>
    <button class="mt-8 px-6 py-3 rounded-lg bg-black text-white font-medium hover:bg-gray-800 transition-colors">Contactanos</button>
</section>---
